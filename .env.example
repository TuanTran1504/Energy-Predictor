# Trading engine tuning (safe defaults = current strict behavior)
TRADE_MIN_RR=1.5
SETUP_E_MIN_RR=1.0
TECH_ALLOW_SIDEWAY=0
TECH_SCORE_THRESHOLD=3
TECH_SCORE_THRESHOLD_RANGE=3
TECH_SCORE_THRESHOLD_NON_BTC_HIGH_ADX=2
TECH_ADX_RELAX_LEVEL=45
TECH_ROLLOVER_SCORE_THRESHOLD=1
SETUP_C_RELAXED=0
SETUP_C_SOFT_BODY_RATIO=0.45
SETUP_C_VOLUME_MULT=1.10
SETUP_C_FAKE_MOVE_ATR_MULT=0.35

# Strategy policy reviewer (scheduler)
