STRATEGY_POLICY_ACCOUNT_TYPE=live
POLICY_REVIEW_ENABLED=1
POLICY_REVIEW_INTERVAL_HOURS=6
POLICY_REVIEW_MIN_HOURS_SINCE_UPDATE=24
POLICY_REVIEW_MIN_CLOSED_TRADES_SINCE_UPDATE=20
POLICY_REVIEW_COOLDOWN_HOURS=12
POLICY_REVIEW_TRADES_TABLE=trades_live
